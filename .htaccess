Options -Indexes

RewriteEngine On

# Rediriger www vers non-www
RewriteCond %{HTTP_HOST} ^www\.spycar\.fr [NC]
RewriteRule ^(.*)$ https://spycar.fr/$1 [R=301,L]

# Supprimer l'extension .html des URLs
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L,QSA]

# Rediriger /blog vers /blog/index.html
RewriteRule ^blog/?$ /blog/index.html [L]
